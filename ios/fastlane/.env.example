# Copy to `fastlane/.env` (do not commit `.env`).
#
# CRITICAL: If MATCH_PASSWORD contains `$`, you MUST wrap the value in single quotes.
# Otherwise `evencalmatch$123` is parsed as `evencalmatch` + empty variable `$123` → AEAD / wrong password errors.
#
# Good:  MATCH_PASSWORD='evencalmatch$123'
# Bad:  MATCH_PASSWORD=evencalmatch$123
MATCH_PASSWORD='replace-with-your-match-passphrase'

# Apple ID used for Apple Developer / App Store Connect.
FASTLANE_USER=your-apple-id@example.com

# Team ID: developer.apple.com → Membership (10 characters).
FASTLANE_TEAM_ID=Y2H26URNHR

# App Store Connect provider id (UUID) if you use pilot/deliver — also set in Appfile.
# FASTLANE_ITC_TEAM_ID=69a6de94-3876-47e3-e053-5b8c7c11a4d1

# --- TestFlight upload (App Store Connect API key; no interactive Apple ID login) ---
# Create key: App Store Connect → Users and Access → Integrations → App Store Connect API → Generate.
# Role must include at least App Manager (or Admin). Download the .p8 once; Apple never shows it again.
#
# Local: put the .p8 in ios/fastlane/ (gitignored) and set PATH (relative to fastlane/ or absolute).
# APP_STORE_CONNECT_API_KEY_KEY_ID=ABCDE12345
# APP_STORE_CONNECT_API_KEY_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# APP_STORE_CONNECT_API_KEY_PATH=./AuthKey_ABCDE12345.p8
#
# CI: instead of PATH, set base64 of the .p8 file contents (openssl base64 -A -in AuthKey_xxx.p8 | tr -d '\n'):
# APP_STORE_CONNECT_API_KEY_CONTENT=<base64-string>
# APP_STORE_CONNECT_API_KEY_CONTENT_IS_BASE64=true

# Match repo (default in Matchfile is GitHub SSH). Override if you use a fork or local clone.
MATCH_GIT_URL=git@github.com:akshaynhegde/evencal-match.git
# Faster offline: clone once (`git clone … ~/evencal-match`) then:
# MATCH_GIT_URL=file:///Users/you/evencal-match

# --- Still seeing "AEAD authentication tag verification failed"? ---
# That means decryption failed: the passphrase is not the one used when this match repo was created.
# Get the exact passphrase from whoever ran `fastlane match` for evencal-match, or run:
#   bundle exec fastlane sync_certificates_prompt
# and type the passphrase manually (bypasses .env).
